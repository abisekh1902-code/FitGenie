# ============================================================
#  FitGenie — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# --- IBM Watsonx.ai Credentials ---
# Get these from https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_cloud_api_key_here

# Your Watsonx project ID (from IBM Watsonx.ai project settings)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Watsonx.ai API endpoint (default: Dallas region)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# --- Model Configuration ---
# Recommended: ibm/granite-4-h-small  (granite-3-8b-instruct was withdrawn 2026-03-31)
# Other options: ibm/granite-3-2b-instruct, ibm/granite-13b-instruct-v2
WATSONX_MODEL_ID=ibm/granite-4-h-small

# --- Flask Configuration ---
# Generate a secure secret key: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your_flask_secret_key_here

# Flask environment: development | production
FLASK_ENV=development

# Port for the Flask server
PORT=5000

# --- Application Settings ---
# Max tokens the model generates per response
MAX_NEW_TOKENS=1024

# Model temperature (0.0 = deterministic, 1.0 = creative)
TEMPERATURE=0.7

# Top-p sampling
TOP_P=0.9
